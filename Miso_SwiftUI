import SwiftUI

// 1. DATA MODEL (The Blueprint)
// This defines what information each "Element" will hold.
struct Element: Identifiable {
    let id = UUID() // Gives each element a unique ID so SwiftUI can tell them apart.
    let name: String
    let symbol: String
    let atomicNumber: Int
    let category: String
}

// 2. VIEW MODEL (The Data Manager)
// Think of this as a "backpack" that carries all your app's data.
class QuizViewModel: ObservableObject {
    // @Published: This tells the app, "If this list changes, update the screen immediately!"
    @Published var elements: [Element] = [
        Element(name: "Hydrogen", symbol: "H", atomicNumber: 1, category: "Nonmetal"),
        Element(name: "Helium", symbol: "He", atomicNumber: 2, category: "Noble Gas"),
        Element(name: "Lithium", symbol: "Li", atomicNumber: 3, category: "Alkali Metal"),
        Element(name: "Beryllium", symbol: "Be", atomicNumber: 4, category: "Alkaline Earth Metal"),
        Element(name: "Boron", symbol: "B", atomicNumber: 5, category: "Metalloid")
    ]
}

// 3. MAIN ENTRY POINT (The App Frame)
// This sets up the main structure, like the tabs at the bottom.
struct ElementQuizApp: View {
    // @StateObject: We create the "Backpack" (ViewModel) here and keep it alive.
    @StateObject private var vm = QuizViewModel()
    
    var body: some View {
        TabView {
            // We pass the list of elements from our backpack to the study view.
            FlashcardView(elements: vm.elements)
                .tabItem {
                    Label("Study", systemImage: "book.fill")
                }
            
            // We pass the same list to the quiz view.
            QuizView(elements: vm.elements)
                .tabItem {
                    Label("Quiz", systemImage: "pencil.circle")
                }
        }
    }
}

// 4. FLASHCARD COMPONENT (The Study Tool)
struct FlashcardView: View {
    let elements: [Element]
    
    // @State: Simple variables that only live inside THIS screen.
    // When these change, SwiftUI automatically "refreshes" the UI.
    @State private var isFlipped = false // Is the card showing the front or back?
    @State private var currentIndex = 0  // Which element are we looking at?
    
    var body: some View {
        VStack(spacing: 30) {
            ZStack {
                // The Card Shape
                RoundedRectangle(cornerRadius: 25)
                    .fill(isFlipped ? Color.blue : Color.white) // Change color based on flip state
                    .shadow(radius: 10)
                
                VStack {
                    if !isFlipped {
                        // FRONT SIDE: Large Symbol
                        Text(elements[currentIndex].symbol)
                            .font(.system(size: 80, weight: .bold))
                    } else {
                        // BACK SIDE: Name and Details
                        Text(elements[currentIndex].name).font(.largeTitle)
                        Text("Atomic #: \(elements[currentIndex].atomicNumber)")
                    }
                }
                .foregroundColor(isFlipped ? .white : .black)
            }
            .frame(width: 300, height: 400)
            // 3D Flip Animation Logic
            .rotation3DEffect(.degrees(isFlipped ? 180 : 0), axis: (x: 0, y: 1, z: 0))
            .onTapGesture {
                // withAnimation makes the flip look smooth instead of instant.
                withAnimation(.spring()) {
                    isFlipped.toggle() // Switches true to false, or false to true.
                }
            }
            
            // Navigation Buttons
            HStack(spacing: 40) {
                Button("Previous") {
                    if currentIndex > 0 { 
                        currentIndex -= 1 
                        isFlipped = false // Reset to front side for the new card
                    }
                }
                .disabled(currentIndex == 0) // Can't go back if it's the first card.
                
                Button("Next") {
                    if currentIndex < elements.count - 1 { 
                        currentIndex += 1 
                        isFlipped = false 
                    }
                }
                .disabled(currentIndex == elements.count - 1) // Can't go forward if it's the last card.
            }
            .buttonStyle(.borderedProminent)
        }
    }
}

// 5. QUIZ COMPONENT (The Testing Tool)
struct QuizView: View {
    let elements: [Element]
    
    @State private var currentQuestionIndex = 0
    @State private var score = 0
    @State private var showingScore = false
    
    var body: some View {
        VStack(spacing: 20) {
            Text("Score: \(score)")
                .font(.title2)
            
            Spacer()
            
            // Question Area
            Text("What is the symbol for")
            Text(elements[currentQuestionIndex].name)
                .font(.system(size: 40, weight: .black))
            
            Spacer()
            
            // Multiple Choice Grid
            LazyVGrid(columns: [GridItem(.flexible()), GridItem(.flexible())], spacing: 20) {
                // Shuffles the cards and picks 4 to show as options.
                ForEach(elements.shuffled().prefix(4), id: \.id) { element in
                    Button(action: {
                        checkAnswer(element.symbol)
                    }) {
                        Text(element.symbol)
                            .font(.title)
                            .frame(maxWidth: .infinity)
                            .padding()
                            .background(Color.gray.opacity(0.1))
                            .cornerRadius(10)
                    }
                }
            }
            .padding()
        }
        // Result Pop-up
        .alert("Quiz Finished!", isPresented: $showingScore) {
            Button("Restart") {
                score = 0
                currentQuestionIndex = 0
            }
        } message: {
            Text("Final Score: \(score) / \(elements.count)")
        }
    }
    
    // Logic to check if the user clicked the right symbol
    func checkAnswer(_ symbol: String) {
        if symbol == elements[currentQuestionIndex].symbol {
            score += 1
        }
        
        // Move to the next question or finish the quiz
        if currentQuestionIndex < elements.count - 1 {
            currentQuestionIndex += 1
        } else {
            showingScore = true
        }
    }
}
