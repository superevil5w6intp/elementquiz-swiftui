import SwiftUI

// 1. DATA MODEL
struct Element: Identifiable {
    let id = UUID()
    let name: String
    let symbol: String
    let atomicNumber: Int
    let category: String
}

// 2. VIEW MODEL
class QuizViewModel: ObservableObject {
    // @Published: A property wrapper that announces to any observing views 
    // whenever this data changes. If you add more elements, the UI updates automatically.
    @Published var elements: [Element] = [
        Element(name: "Hydrogen", symbol: "H", atomicNumber: 1, category: "Nonmetal"),
        Element(name: "Helium", symbol: "He", atomicNumber: 2, category: "Noble Gas"),
        Element(name: "Lithium", symbol: "Li", atomicNumber: 3, category: "Alkali Metal"),
        Element(name: "Beryllium", symbol: "Be", atomicNumber: 4, category: "Alkaline Earth Metal"),
        Element(name: "Boron", symbol: "B", atomicNumber: 5, category: "Metalloid")
    ]
}

// 3. MAIN ENTRY POINT
struct ElementQuizApp: View {
    // @StateObject: Used to create and "own" an ObservableObject. 
    // This ensures the data stays alive as long as the app is running.
    @StateObject private var vm = QuizViewModel()
    
    var body: some View {
        TabView {
            FlashcardView(elements: vm.elements)
                .tabItem {
                    Label("Study", systemImage: "book.fill")
                }
            
            QuizView(elements: vm.elements)
                .tabItem {
                    Label("Quiz", systemImage: "pencil.circle")
                }
        }
    }
}

// 4. FLASHCARD COMPONENT
struct FlashcardView: View {
    let elements: [Element]
    
    // @State: This is for simple data that stays inside a single view.
    // When isFlipped changes, SwiftUI re-draws this view only.
    @State private var isFlipped = false
    @State private var currentIndex = 0
    
    var body: some View {
        VStack(spacing: 30) {
            ZStack {
                RoundedRectangle(cornerRadius: 25)
                    .fill(isFlipped ? Color.blue : Color.white)
                    .shadow(radius: 10)
                
                VStack {
                    if !isFlipped {
                        Text(elements[currentIndex].symbol)
                            .font(.system(size: 80, weight: .bold))
                    } else {
                        Text(elements[currentIndex].name).font(.largeTitle)
                        Text("Atomic #: \(elements[currentIndex].atomicNumber)")
                    }
                }
                .foregroundColor(isFlipped ? .white : .black)
            }
            .frame(width: 300, height: 400)
            // 3D Effect: Uses the isFlipped @State to determine the angle
            .rotation3DEffect(.degrees(isFlipped ? 180 : 0), axis: (x: 0, y: 1, z: 0))
            .onTapGesture {
                // withAnimation: Tells SwiftUI to animate the change from 0 to 180 degrees
                withAnimation(.spring()) {
                    isFlipped.toggle()
                }
            }
            
            HStack(spacing: 40) {
                Button("Previous") {
                    if currentIndex > 0 { currentIndex -= 1; isFlipped = false }
                }
                .disabled(currentIndex == 0)
                
                Button("Next") {
                    if currentIndex < elements.count - 1 { currentIndex += 1; isFlipped = false }
                }
                .disabled(currentIndex == elements.count - 1)
            }
            .buttonStyle(.borderedProminent)
        }
    }
}

// 5. QUIZ COMPONENT
struct QuizView: View {
    let elements: [Element]
    
    @State private var currentQuestionIndex = 0
    @State private var score = 0
    @State private var showingScore = false
    
    var body: some View {
        VStack(spacing: 20) {
            Text("Score: \(score)")
                .font(.title2)
            
            Spacer()
            
            Text("What is the symbol for")
            Text(elements[currentQuestionIndex].name)
                .font(.system(size: 40, weight: .black))
            
            Spacer()
            
            // LazyVGrid: A layout concept that organizes views into columns
            LazyVGrid(columns: [GridItem(.flexible()), GridItem(.flexible())], spacing: 20) {
                ForEach(elements.shuffled().prefix(4), id: \.id) { element in
                    Button(action: {
                        checkAnswer(element.symbol)
                    }) {
                        Text(element.symbol)
                            .font(.title)
                            .frame(maxWidth: .infinity)
                            .padding()
                            .background(Color.gray.opacity(0.1))
                            .cornerRadius(10)
                    }
                }
            }
            .padding()
        }
        // .alert: A modifier that listens to the @State showingScore.
        // When showingScore becomes true, the pop-up appears.
        .alert("Quiz Finished!", isPresented: $showingScore) {
            Button("Restart") {
                score = 0
                currentQuestionIndex = 0
            }
        } message: {
            Text("Final Score: \(score) / \(elements.count)")
        }
    }
    
    func checkAnswer(_ symbol: String) {
        if symbol == elements[currentQuestionIndex].symbol {
            score += 1
        }
        
        if currentQuestionIndex < elements.count - 1 {
            currentQuestionIndex += 1
        } else {
            showingScore = true
        }
    }
}

